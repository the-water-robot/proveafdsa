# ─── Credenziali Google OAuth (account proprietario della cartella Drive, "u/1") ───
# Crea un OAuth client "Desktop app" su https://console.cloud.google.com (Drive API abilitata).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Generato una volta sola con:  npm run get-token
GOOGLE_REFRESH_TOKEN=

# Cartella Drive di destinazione (le prove vanno in sottocartelle qui dentro).
DRIVE_FOLDER_ID=1jsOe6y1KC8ekYVceRPrHC2RLNyf5Hqxa

# Opzionale: lascia VUOTO per "link aperto". Se valorizzi, l'app chiede questo codice una volta.
UPLOAD_PIN=
